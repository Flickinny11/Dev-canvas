# Environment Variables for The Experience Platform
# Copy this file to .env.local and fill in your actual values

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# JWT Secret for authentication
JWT_SECRET=your-jwt-secret-key-here

# OpenRouter API Configuration
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Database Configuration (when ready to move from in-memory storage)
# DATABASE_URL=postgresql://username:password@localhost:5432/experience_db

# Optional: Enable specific features
FEATURE_DEPLOYMENT=true
FEATURE_COLLABORATION=true
FEATURE_MONITORING=true